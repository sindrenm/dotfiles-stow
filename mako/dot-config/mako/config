include=~/.config/mako/catppuccin-mocha-blue

anchor=top-right
layer=overlay

width=420
height=300

outer-margin=20
padding=16

border-size=2
border-radius=10

font="JetBrainsMono Nerd Font 12"
max-icon-size=48
format=<b>%s</b>\n%b

max-visible=5

actions=1
icons=1
markup=1

[urgency=low]
default-timeout=2000

[urgency=normal]
default-timeout=3000

[urgency=critical]
default-timeout=0
ignore-timeout=1

